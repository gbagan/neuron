{
  "dependencies": {
    "@shoelace-style/shoelace": "^2.0.0-beta.73",
    "esbuild": "^0.16.10",
    "purescript": "^0.15.7",
    "rimraf": "^3.0.2",
    "sass": "^1.51.0",
    "spago": "^0.20.9",
    "tailwindcss": "^3.2.4"
  },
  "scripts": {
    "clean": "rimraf output && rimraf .spago",
    "build": "spago bundle-app --minify --to dist/bundle.js",
    "buildcss": "sass --no-source-map src/style.scss dist/bundle.css",
    "build-shoelace": "esbuild --bundle shoelace/index.js --minify --outfile=dist/shoelace.js"
  }
}
