{
  "dependencies": {
    "esbuild": "^0.17.18",
    "purescript": "^0.15.9",
    "purs-backend-es": "^1.3.2",
    "rimraf": "^5.0.0",
    "sass": "^1.62.1",
    "spago": "^0.20.9",
    "tailwindcss": "^3.3.2"
  },
  "scripts": {
    "clean": "rimraf output && rimraf .spago",
    "build": "spago bundle-app --to dist/bundle.js",
    "buildopt": "spago -x opt.dhall build && purs-backend-es bundle-app --no-build --minify --to dist/bundle.js",
    "buildcss": "tailwindcss -i src/tailwind.css -o dist/tailwind.css"
  }
}
